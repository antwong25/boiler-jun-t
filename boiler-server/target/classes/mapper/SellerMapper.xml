<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.boilerserver.mapper.SellerMapper">
    <resultMap id="SellerResultMap" type="org.example.boilerpojo.SellerEntity">
        <id property="sellerId" column="sellerId"/>
        <result property="shopName" column="shopName"/>
        <result property="shopAddress" column="shopAddress"/>
        <result property="businessLicense" column="businessLicense"/>
        <result property="legalPersonId" column="legalPersonId"/>
        <result property="businessLicenseFileUrl" column="businessLicenseFileUrl"/>
        <result property="legalPersonIdFileUrl" column="legalPersonIdFileUrl"/>
        <result property="qualificationStatus" column="qualificationStatus"/>
        <result property="qualificationAuditRemark" column="qualificationAuditRemark"/>
        <result property="qualificationAuditedBy" column="qualificationAuditedBy"/>
        <result property="qualificationAuditTime" column="qualificationAuditTime"/>
        <result property="guaranteeDeposit" column="guaranteeDeposit"/>
        <result property="completedTransactionCount" column="completedTransactionCount"/>
        <result property="positiveRatingRate" column="positiveRatingRate"/>
    </resultMap>

    <select id="getByUserId" resultMap="SellerResultMap">
        select * from seller where sellerId = #{userId}
    </select>

    <select id="getBySellerId" resultMap="SellerResultMap">
        select * from seller where sellerId = #{sellerId}
    </select>

    <insert id="insert" parameterType="org.example.boilerpojo.SellerEntity">
        insert into seller (
            sellerId,
            shopName,
            shopAddress,
            businessLicense,
            legalPersonId,
            businessLicenseFileUrl,
            legalPersonIdFileUrl,
            qualificationStatus,
            qualificationAuditRemark,
            qualificationAuditedBy,
            qualificationAuditTime,
            guaranteeDeposit,
            completedTransactionCount,
            positiveRatingRate
        )
        values (
            #{sellerId},
            #{shopName},
            #{shopAddress},
            #{businessLicense},
            #{legalPersonId},
            #{businessLicenseFileUrl},
            #{legalPersonIdFileUrl},
            #{qualificationStatus},
            #{qualificationAuditRemark},
            #{qualificationAuditedBy},
            #{qualificationAuditTime},
            #{guaranteeDeposit},
            #{completedTransactionCount},
            #{positiveRatingRate}
        )
    </insert>

    <update id="update" parameterType="org.example.boilerpojo.SellerEntity">
        update seller
        <set>
            <if test="shopName != null and shopName != ''">shopName = #{shopName},</if>
            <if test="shopAddress != null">shopAddress = #{shopAddress},</if>
            <if test="businessLicense != null">businessLicense = #{businessLicense},</if>
            <if test="legalPersonId != null">legalPersonId = #{legalPersonId},</if>
            <if test="businessLicenseFileUrl != null">businessLicenseFileUrl = #{businessLicenseFileUrl},</if>
            <if test="legalPersonIdFileUrl != null">legalPersonIdFileUrl = #{legalPersonIdFileUrl},</if>
            <if test="qualificationStatus != null and qualificationStatus != ''">qualificationStatus = #{qualificationStatus},</if>
            <if test="qualificationAuditRemark != null">qualificationAuditRemark = #{qualificationAuditRemark},</if>
            <if test="qualificationAuditedBy != null">qualificationAuditedBy = #{qualificationAuditedBy},</if>
            <if test="qualificationAuditTime != null">qualificationAuditTime = #{qualificationAuditTime},</if>
            <if test="guaranteeDeposit != null">guaranteeDeposit = #{guaranteeDeposit},</if>
            <if test="completedTransactionCount != null">completedTransactionCount = #{completedTransactionCount},</if>
            <if test="positiveRatingRate != null">positiveRatingRate = #{positiveRatingRate},</if>
        </set>
        where sellerId = #{sellerId}
    </update>
</mapper>
