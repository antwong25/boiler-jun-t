<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.boilerserver.mapper.BuyerMapper">
    <resultMap id="BuyerResultMap" type="org.example.boilerpojo.BuyerEntity">
        <id property="buyerId" column="buyerId"/>
    </resultMap>

    <select id="getByUserId" resultMap="BuyerResultMap">
        select * from buyer where buyerId = #{userId}
    </select>

    <select id="getByBuyerId" resultMap="BuyerResultMap">
        select * from buyer where buyerId = #{buyerId}
    </select>

    <insert id="insert" parameterType="org.example.boilerpojo.BuyerEntity">
        insert into buyer (buyerId)
        values (#{buyerId})
    </insert>
</mapper>
